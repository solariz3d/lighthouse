{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Consonance",
  "version": "0.1.0",
  "identifier": "com.solariz3d.consonance",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Consonance",
        "width": 840,
        "height": 600,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
